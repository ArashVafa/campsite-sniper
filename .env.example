# Copy this to .env and fill in your values
# Never commit .env to git

# Recreation.gov API key (get one at ridb.recreation.gov)
RIDB_API_KEY=your-ridb-api-key-here

# Auth token signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Email notifications (Gmail + App Password)
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ntfy.sh fallback topic (used if a user hasn't set their own)
NTFY_TOPIC=your-ntfy-topic

# How often to poll Recreation.gov (minutes)
POLL_INTERVAL_MINUTES=5

# Your deployed frontend URL (for CORS) — e.g. https://campsite-sniper.up.railway.app
# Leave as default for local dev
FRONTEND_ORIGIN=http://localhost:5173

# Twilio SMS (optional, not yet wired up)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_PHONE=
# TWILIO_TO_PHONE=
